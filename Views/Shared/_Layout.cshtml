<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="/images/favicon/icon.ico?v=2" type="image/x-icon">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>
    @* ipconfig *@
    <div id="root">
        <div class="Content-Wrapper max-w-screen-2xl mx-auto text-base ">
            <header id="main-header"
                    class="fixed top-0 left-0 w-full z-50 bg-transparent text-white transition-all duration-500">
                <nav id="header-inner"
                     class="relative max-w-[1440px] mx-auto px-6 flex justify-between items-center h-20 transition-all duration-300">

                    <div class="absolute z-10 right-6 md:static md:flex-1 md:flex md:justify-start">
                        <div id="menu-toggle"
                             class="menu cursor-pointer menu-toggle ct-menuToggle p-2 hover:opacity-70 transition-opacity">
                            <i class="fa-solid fa-bars text-xl"></i>
                        </div>
                    </div>

                    <div id="drawer-backdrop"
                         class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300">
                    </div>

                    <div id="sidebar-drawer"
                         class="fixed top-0 left-0 h-full w-[85vw] max-w-sm bg-black/85 backdrop-blur-xl text-white z-50 transform -translate-x-full transition-transform duration-300 ease-in-out flex flex-col justify-between p-6 overflow-y-auto select-none">
                        <div>
                            <div id="drawer-tabs"
                                 class="flex items-center space-x-2 mb-8 text-sm font-bold overflow-x-auto whitespace-nowrap pb-2 scrollbar-none">
                                <span data-tab="featured" class="tab-btn ct-tabBtn bg-white text-black">Featured</span>
                                <span data-tab="women" class="tab-btn ct-tabBtn">Women</span>
                                <span data-tab="men" class="tab-btn ct-tabBtn">Men</span>
                                <span data-tab="kids" class="tab-btn ct-tabBtn">Kids</span>
                            </div>
                            <div id="drawer-menu-items"
                                 class="space-y-5 text-[17px] font-bold tracking-wide min-h-[300px]"></div>
                            <hr class="border-white/10 my-6" />
                            <div class="mb-6">
                                <div class="font-serif italic text-lg text-gray-300">Customs</div>
                                <div class="text-2xl font-black tracking-wider mt-0.5">OTW</div>
                            </div>
                            <hr class="border-white/10 my-6" />
                            <div class="space-y-4 text-sm font-medium text-gray-300">
                                <div class="ct-sidebar-link">Vans Family</div>
                                <div class="ct-sidebar-link">Favorites</div>
                                <div class="ct-sidebar-link">News</div>
                            </div>
                        </div>
                        <div class="absolute bottom-6 right-6">
                            <button id="close-drawer"
                                    class="w-12 h-12 bg-white text-black flex items-center justify-center rounded-xs shadow-lg hover:bg-gray-200 active:scale-95 transition-all duration-200">
                                <i class="fa-solid fa-xmark text-xl"></i>
                            </button>
                        </div>
                    </div>

                    <div
                        class="logo static transform-none z-10 -ml-6 md:ml-0 md:absolute  md:left-1/2 md:-translate-x-1/2">
                        <a href="" class="block">
                            <img id="header-logo" src="~/images/Logos/logo1.png" alt="Vans"
                                 class="h-17 w-auto object-contain brightness-0 invert transition-transform duration-300 hover:-rotate-6">
                        </a>
                    </div>

                    <ul class="z-10 flex items-center gap-6 absolute right-20 flex-row-reverse 
                        md:static md:flex-1 md:flex-row md:justify-end md:gap-10">
                        <li class="relative">
                            <a href="" class="menu-toggle ct-menuToggle">
                                <i class="fa-solid fa-cart-arrow-down text-xl"></i>
                            </a>
                            <span
                                class="absolute -top-2 -right-2 bg-red-600 text-[10px] w-4 h-4 flex items-center justify-center rounded-full font-bold">
                                1
                            </span>
                        </li>
                        <li>
                            <a asp-controller="Account" asp-action="Login" class="menu-toggle ct-menuToggle">
                                <i class="fa-regular fa-user text-xl"></i>
                            </a>
                        </li>
                        <li>
                            <a href="" class="menu-toggle ct-menuToggle">
                                <i class="fa-solid fa-magnifying-glass text-xl"></i>
                            </a>
                        </li>
                    </ul>

                </nav>
            </header>
            <main class="">
                @RenderBody()
            </main>

            <footer class=" w-[95%] xl:w-[65%] mx-auto pb-24 text-gray-500 text-sm ">
                <div class=" flex flex-col md:flex-row text-center md:text-left gap-8 ">
                    <div class=" basis-2/6">
                        <div class="font-bold text-3xl mb-4 text-gray-800">
                            AdidopShop
                        </div>
                        <div class=" mb-8 md:mb-20">
                            Delivering the ultimate sneaker journey since 2026. From sole geeks to the true heads
                        </div>
                        <div class="text-gray-400 hover:text-light-coffee">
                            AdidopShop Inc. © 2026
                        </div>
                    </div>
                    <div class="basis-1/6">
                        <div class="uppercase font-semibold tracking-wider text-gray-600 mb-4 "> Menu</div>
                        <div class="flex flex-col gap-3">
                            <div class=""><a href="" class="hover:text-light-coffee">Home</a></div>
                            <div class=""><a href="" class="hover:text-light-coffee">Our Products</a></div>
                            <div class=""><a href="" class="hover:text-light-coffee">About</a></div>
                            <div class=""><a href="" class="hover:text-light-coffee">Contact</a></div>
                            <div class=""><a href="" class="hover:text-light-coffee">Styleleguide</a></div>
                            <div class=""><a href="https://github.com/awtichcoder" target="_blank"
                                                 class="">AdidopShop</a></div>
                            </div>
                        </div>
                        <div class="basis-1/6">
                            <div class="uppercase font-semibold tracking-wider text-gray-600 mb-4"> Follow Us</div>
                            <div class="flex flex-col gap-3">
                                <div class=""><a href="" class="hover:text-light-coffee">Facebook</a></div>
                                <div class=""><a href="" class="hover:text-light-coffee">Instagram</a></div>
                                <div class=""><a href="" class="hover:text-light-coffee">Github</a></div>
                                <div class=""><a href="" class="hover:text-light-coffee">Linkedin</a></div>

                            </div>
                        </div>
                        <div class="basis-2/6">
                            <div>
                                <div class="uppercase font-semibold tracking-wider text-gray-600 mb-4"> Contact Us</div>
                                <div class=" mb-4"> We&apos;re Always Happy to Help</div>
                                <div class="mb-16 text-gray-800 text-2xl font-medium tracking-wider"><a
                                    href="mailto:awtichcoder@gmail.com"
                                    class=" hover:text-light-coffee">AdidopShop@gmail.com</a>
                                </div>
                                <div class=""> <a href="" target="_blank"
                                                  class="hover:text-light-coffee text-gray-400">Powered by
                                    TeamAdidop Author</a></div>
                                </div>


                            </div>
                        </div>
                    </footer>
                </div>
            </div>


            <script src=" /lib/jquery/dist/jquery.min.js">
            </script>
            <script type="module" src="~/js/site.js" asp-append-version="true"></script>
            @await RenderSectionAsync("Scripts", required: false)

               

                             
        </body>

    </html>