@{
    ViewData["Title"] = "Adidop Family | Adidop ";
    Layout = "~/Views/Shared/_LayoutProduct.cshtml";
}
<div class="relative w-72 mt-8">
    <input type="text" id="outlined_input" placeholder=" "
           class="peer block w-full px-4 py-3 text-base text-gray-900 bg-transparent border-2 border-gray-300 rounded-md appearance-none focus:outline-none focus:ring-0 focus:border-blue-600 transition-colors" />
    <label for="outlined_input" class="absolute left-3 top-3 px-1 bg-white text-gray-500 text-base transition-all duration-200 transform origin-left pointer-events-none 
        -translate-y-6 scale-75 
        peer-placeholder-shown:translate-y-0 peer-placeholder-shown:scale-100 
        peer-focus:-translate-y-6 peer-focus:scale-75 peer-focus:text-blue-600">
        Outlined
    </label>
</div>