@{
    ViewData["Title"] = "Register | Adidop ";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}
<div class="flex min-h-screen w-full">

    <div class="flex w-full items-center justify-center bg-white px-6 py-12 md:w-1/2 lg:px-16">
        <div class="w-full max-w-md">
            <h1 class="mb-2 text-3xl font-bold text-gray-900">Create an Account</h1>
            <p class="mb-8 text-sm text-gray-500">Please enter your details to register</p>

            <form action="#" method="POST" class="space-y-4">

                <div>
                    <label for="fullName" class="mb-1 block text-sm font-semibold text-gray-900">Full Name</label>
                    <input type="text" id="fullName" placeholder="Enter your full name" required
                           class="w-full rounded-md border border-gray-300 px-4 py-2.5 text-sm placeholder-gray-400 focus:border-black focus:outline-none focus:ring-1 focus:ring-black">
                </div>

                <div>
                    <label for="phone" class="mb-1 block text-sm font-semibold text-gray-900">Phone Number</label>
                    <input type="tel" id="phone" placeholder="Enter your phone number" required
                           class="w-full rounded-md border border-gray-300 px-4 py-2.5 text-sm placeholder-gray-400 focus:border-black focus:outline-none focus:ring-1 focus:ring-black">
                </div>

                <div>
                    <label for="email" class="mb-1 block text-sm font-semibold text-gray-900">Email</label>
                    <input type="email" id="email" placeholder="Enter your email" required
                           class="w-full rounded-md border border-gray-300 px-4 py-2.5 text-sm placeholder-gray-400 focus:border-black focus:outline-none focus:ring-1 focus:ring-black">
                </div>

                <div>
                    <label for="password" class="mb-1 block text-sm font-semibold text-gray-900">Password</label>
                    <input type="password" id="password" placeholder="Create a password" required
                           class="w-full rounded-md border border-gray-300 px-4 py-2.5 text-sm placeholder-gray-400 focus:border-black focus:outline-none focus:ring-1 focus:ring-black">
                </div>

                <button type="button" onclick="window.location.href='@Url.Action("Login", "Account")' "
                        class="mt-2 w-full rounded-md bg-black py-2.5 font-semibold text-white transition duration-200 hover:bg-gray-800">
                    Sign up

                </button>

               
                <button type="button"
                        class="mt-4 flex w-full items-center justify-center gap-2 rounded-md border border-gray-300 bg-white py-2.5 font-semibold text-gray-900 transition duration-200 hover:bg-gray-50">
                    <svg class="h-5 w-5" viewBox="0 0 24 24">
                        <path fill="#4285F4"
                              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853"
                              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05"
                              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                        <path fill="#EA4335"
                              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                    </svg>
                    Sign up with Google
                </button>
            </form>

            <p class="mt-8 text-center text-sm text-gray-500">
                Already have an account? <a asp-action="Login" class="font-bold text-gray-900 hover:underline">Sign
                in</a>
            </p>
        </div>
    </div>

    <div class="hidden w-full h-[100vh] bg-black md:block md:w-1/2">
        <img src="~/images/media/Login2.jpg" alt="error...." class="h-full w-full object-cover ">
    </div>

</div>